<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="is_odoo_agenda19.GoogleCalendarControllerGroupPatch"
       t-inherit="calendar.AttendeeCalendarController"
       t-inherit-mode="extension">
        <xpath expr="//div[@id='google_calendar_sync']" position="attributes">
            <attribute name="t-if">model.googleCredentialsSet and !model.googleIsSync and !model.googleIsPaused and (isGoogleSyncGroupMember or isSystemUser)</attribute>
        </xpath>
    </t>
</templates>
